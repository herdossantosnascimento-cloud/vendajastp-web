export const renewListing = onCall(async (request) => {
  const auth = request.auth;
  if (!auth) {
    throw new HttpsError("unauthenticated", "Login required.");
  }

  const uid = auth.uid;
  const listingId = String((request.data as any)?.listingId || "").trim();

  if (!listingId) {
    throw new HttpsError("invalid-argument", "listingId required.");
  }

  const db = admin.firestore();

  const listingRef = db.collection("listings").doc(listingId);
  const listingSnap = await listingRef.get();

  if (!listingSnap.exists) {
    throw new HttpsError("not-found", "Listing not found.");
  }

  const listing = listingSnap.data() as any;

  if (!listing.ownerId || listing.ownerId !== uid) {
    throw new HttpsError("permission-denied", "You do not own this listing.");
  }

  const userRef = db.collection("users").doc(uid);
  const userSnap = await userRef.get();
  const userData = userSnap.exists ? (userSnap.data() as any) : {};

  const rawPlan = userData?.plan === "pro" ? "monthly" : userData?.plan;
  const planStatus = userData?.planStatus;
  const planExpiresAt = userData?.planExpiresAt;

  let effectivePlan: "free" | "monthly" | "annual" = "free";

  if (
    (rawPlan === "monthly" || rawPlan === "annual") &&
    planStatus === "active" &&
    planExpiresAt &&
    typeof planExpiresAt.toDate === "function" &&
    planExpiresAt.toDate().getTime() > Date.now()
  ) {
    effectivePlan = rawPlan;
  }

  if (effectivePlan === "free") {
    throw new HttpsError(
      "failed-precondition",
      "Active paid plan required to renew listing."
    );
  }

  const days = effectivePlan === "annual" ? 90 : 30;
  const now = admin.firestore.Timestamp.now();
  const newExpiresAt = admin.firestore.Timestamp.fromMillis(
    now.toMillis() + days * 24 * 60 * 60 * 1000
  );

  await listingRef.set(
    {
      status: "active",
      expiresAt: newExpiresAt,
      renewedAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    },
    { merge: true }
  );

  return {
    ok: true,
    listingId,
    effectivePlan,
    expiresAt: newExpiresAt,
  };
});
